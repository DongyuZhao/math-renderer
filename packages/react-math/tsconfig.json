{
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": false,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "lib": ["DOM", "ES2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022"
    },
    "include": ["src/**/*"]
}
